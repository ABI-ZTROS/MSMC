<!-- 🏠 主窗口 —— McServerGuard 的大本营 -->
<!-- 改造重点：WindowChrome 无边框 + 自定义标题栏 + 鼠标悬停自动展开侧边栏 -->
<Window x:Class="McServerGuard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:McServerGuard.Views"
        xmlns:vm="clr-namespace:McServerGuard.ViewModels"
        xmlns:converters="clr-namespace:McServerGuard.Converters"
        Title="MSMC - Minecraft Server Management Console"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource MaterialDesignPaper}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource AppFontFamily}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      NonClientFrameEdges="None"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/McServerGuard;component/Themes/AppResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolStringConverter x:Key="BoolStringConverter" />
            <converters:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter" />
            <converters:IndexToBoolConverter x:Key="IndexToBoolConverter" />
            <converters:BoolToPackIconConverter x:Key="BoolToPackIconConverter" />
            <converters:BoolToTextConverter x:Key="BoolToTextConverter" />
            <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <converters:ValueTypeToVisibilityConverter x:Key="ValueTypeToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- 📐 整体布局：自定义标题栏 + 两列（导航 | 内容）+ 底部状态栏 -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 🎨 自定义标题栏 -->
            <RowDefinition Height="*" />     <!-- 📑 中间内容区 -->
            <RowDefinition Height="Auto" />  <!-- 📊 底部状态栏 -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56" x:Name="NavColumn" /> <!-- 🧭 导航面板（可自动展开/折叠） -->
            <ColumnDefinition Width="*" />    <!-- 📄 主内容区 -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- 🎨 自定义标题栏 —— 可拖动，覆盖两列                          -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                x:Name="TitleBar"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardSubtleBorderBrush}"
                BorderThickness="0,0,0,1"
                Height="40"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- 图标+标题 -->
                    <ColumnDefinition Width="*" />      <!-- 中间空白（可拖动） -->
                    <ColumnDefinition Width="Auto" />   <!-- 窗口控制按钮 -->
                </Grid.ColumnDefinitions>

                <!-- 🛡️ 标题（左侧） -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <iconPacks:PackIconFontAwesome6 Kind="ShieldSolid"
                                            Width="18" Height="18"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0"
                                            Foreground="{DynamicResource NavItemSelectedBrush}" />
                    <TextBlock Text="MSMC"
                               FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBody}" />
                    <TextBlock Text="Minecraft Server Management Console"
                               FontSize="11"
                               Opacity="0.5"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBody}" />
                </StackPanel>

                <!-- 🪟 窗口控制按钮（右侧） -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="最小化">
                        <iconPacks:PackIconFontAwesome6 Kind="WindowMinimizeSolid" Width="10" Height="10" />
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="MaximizeButton_Click"
                            ToolTip="最大化">
                        <iconPacks:PackIconFontAwesome6 x:Name="MaximizeIcon"
                                                Kind="WindowMaximizeSolid" Width="10" Height="10" />
                    </Button>
                    <Button x:Name="CloseButton"
                            Style="{StaticResource WindowCloseButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="关闭">
                        <iconPacks:PackIconFontAwesome6 Kind="XmarkSolid" Width="12" Height="12" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- 🧭 左侧导航面板 —— 鼠标悬停自动展开/折叠                       -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0"
                x:Name="NavSidebar"
                Width="240"
                HorizontalAlignment="Left"
                Panel.ZIndex="10"
                SnapsToDevicePixels="True"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardSubtleBorderBrush}"
                BorderThickness="0,0,1,0"
                MouseEnter="NavSidebar_MouseEnter"
                MouseLeave="NavSidebar_MouseLeave">
            <Border.Clip>
                <RectangleGeometry x:Name="NavSidebarClip" Rect="0,0,56,10000" />
            </Border.Clip>

            <Grid Width="240">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 🏷️ 导航头部 - 仅展开时显示文字部分 -->
                <Border Grid.Row="0" Padding="12,16,12,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{DynamicResource PrimarySubtleBackgroundBrush}" Offset="0" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32"
                                CornerRadius="8"
                                Background="{DynamicResource PrimarySubtleBorderBrush}">
                            <iconPacks:PackIconFontAwesome6 Kind="ShieldSolid"
                                                    Width="20" Height="20"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource NavItemSelectedBrush}" />
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center"
                                    x:Name="NavHeaderText"
                                    Opacity="1">
                            <TextBlock Text="MSMC"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesignBody}" />
                            <TextBlock Text="v0.1.0"
                                       FontSize="10"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource MaterialDesignBody}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 📋 导航列表 -->
                <ListBox Grid.Row="1"
                         x:Name="NavListBox"
                         SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                         VerticalAlignment="Top"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource MaterialDesignBody}"
                         Style="{StaticResource ModernNavListBoxStyle}"
                         ItemContainerStyle="{StaticResource ModernNavListBoxItemStyle}"
                         VirtualizingStackPanel.IsVirtualizing="False"
                         Margin="0,4,0,0">

                    <ListBoxItem ToolTip="服务器管理">
                        <StackPanel Orientation="Horizontal" Margin="4,4">
                            <iconPacks:PackIconFontAwesome6 Kind="ServerSolid" Width="22" Height="22" Margin="0,0,12,0" />
                            <TextBlock x:Name="NavItemText1" Text="服务器管理" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem ToolTip="配置编辑">
                        <StackPanel Orientation="Horizontal" Margin="4,4">
                            <iconPacks:PackIconFontAwesome6 Kind="FilePenSolid" Width="22" Height="22" Margin="0,0,12,0" />
                            <TextBlock x:Name="NavItemText2" Text="配置编辑" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem ToolTip="系统监控">
                        <StackPanel Orientation="Horizontal" Margin="4,4">
                            <iconPacks:PackIconFontAwesome6 Kind="GaugeHighSolid" Width="22" Height="22" Margin="0,0,12,0" />
                            <TextBlock x:Name="NavItemText3" Text="系统监控" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem ToolTip="AI 守护">
                        <StackPanel Orientation="Horizontal" Margin="4,4">
                            <iconPacks:PackIconFontAwesome6 Kind="ShieldHalvedSolid" Width="22" Height="22" Margin="0,0,12,0" />
                            <TextBlock x:Name="NavItemText4" Text="AI 守护" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem ToolTip="设置">
                        <StackPanel Orientation="Horizontal" Margin="4,4">
                            <iconPacks:PackIconFontAwesome6 Kind="GearSolid" Width="22" Height="22" Margin="0,0,12,0" />
                            <TextBlock x:Name="NavItemText5" Text="设置" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- 🔻 底部信息 - 仅展开时显示 -->
                <Border Grid.Row="2"
                        Padding="12,10"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource CardSubtleBorderBrush}"
                        x:Name="NavFooter"
                        Opacity="1">
                    <Border Background="{DynamicResource PrimarySubtleBorderBrush}"
                            CornerRadius="6"
                            Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconFontAwesome6 Kind="CircleInfoSolid"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0"
                                                    Foreground="{DynamicResource NavItemSelectedBrush}" />
                            <StackPanel>
                                <TextBlock Text="MSMC"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MaterialDesignBody}" />
                                <TextBlock Text="v0.1.0"
                                           FontSize="9"
                                           Opacity="0.5"
                                           Foreground="{DynamicResource MaterialDesignBody}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- 📑 中间 ContentControl —— 六大页面切换（带动画）              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ContentControl Grid.Row="1" Grid.Column="1" Margin="8"
                        Content="{Binding CurrentPage}"
                        Opacity="0"
                        x:Name="MainContent">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:ServerDetectionViewModel}">
                    <local:ServerDetectionPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ConfigEditorViewModel}">
                    <local:ConfigEditorPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SystemMonitorViewModel}">
                    <local:SystemMonitorPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AIGuardViewModel}">
                    <local:AIGuardPage />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <local:SettingsPage />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- 📊 底部状态栏 —— 覆盖两列                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <materialDesign:ColorZone Grid.Row="2" Grid.ColumnSpan="2"
                                  Mode="PrimaryDark"
                                  Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <iconPacks:PackIconFontAwesome6 Kind="CircleInfoSolid"
                                            Width="16" Height="16"
                                            VerticalAlignment="Center"
                                            Margin="0,0,6,0" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBody}" />
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentTime}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           Opacity="0.7" />
            </Grid>
        </materialDesign:ColorZone>

        <!-- 📢 Snackbar 弹出通知 -->
        <materialDesign:Snackbar MessageQueue="{Binding SnackbarMessages}"
                                 Grid.Row="2" Grid.ColumnSpan="2" />
    </Grid>

</Window>
