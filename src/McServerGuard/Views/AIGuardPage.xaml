<!-- 🤖 AI 守护页面 —— "我是 AI 助手，专治服务器各种疑难杂症" -->
<UserControl x:Class="McServerGuard.Views.AIGuardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:McServerGuard.Converters">

    <UserControl.Resources>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="8">
        <StackPanel>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- 🤖 AI 状态卡片：渐变背景 + 引擎状态 -->
            <!-- ═══════════════════════════════════════════════ -->
            <materialDesign:Card Margin="0,0,0,8"
                                 Padding="0"
                                 Background="{DynamicResource AccentGradientBrush}">
                <!-- 内层用白色半透明让内容可读 -->
                <Border Padding="16"
                        Background="{DynamicResource MaterialDesignPaper}"
                        Opacity="0.95">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 🧠 引擎状态图标 -->
                        <iconPacks:PackIconFontAwesome6 Grid.Column="0"
                                                Kind="ShieldHalvedSolid"
                                                Width="40" Height="40"
                                                VerticalAlignment="Center"
                                                Margin="0,0,16,0" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="智能守护引擎"
                                       FontSize="18" FontWeight="Bold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="规则引擎 + 自学习模式 · 运行中"
                                       FontSize="13"
                                       Opacity="0.8" />
                            <TextBlock Text="支持 8 种日志异常模式 · 崩溃预测基于滑动窗口 · 自动从日志中学习新模式"
                                       FontSize="11"
                                       Opacity="0.6"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </materialDesign:Card>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- 🛠️ 功能按钮：生成健康报告 / 配置优化建议 -->
            <!-- ═══════════════════════════════════════════════ -->
            <materialDesign:Card Margin="0,0,0,8" Padding="16">
                <StackPanel>
                    <TextBlock Text="AI 功能"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <!-- 🩺 生成服务器健康报告 -->
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding GenerateHealthReportCommand}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="HeartSolid"
                                                        Width="18" Height="18"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0" />
                                <TextBlock Text="生成健康报告"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- 🚀 配置优化建议 -->
                        <Button Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                Command="{Binding RequestConfigOptimizationCommand}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="ShieldHalvedSolid"
                                                        Width="18" Height="18"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0" />
                                <TextBlock Text="配置优化建议"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- 📝 日志分析输入区 -->
            <!-- ═══════════════════════════════════════════════ -->
            <materialDesign:Card Margin="0,0,0,8" Padding="16">
                <StackPanel>
                    <TextBlock Text="日志分析"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="粘贴服务器日志，AI 帮你找出异常行 📋"
                               FontSize="12" Opacity="0.7"
                               Margin="0,0,0,8" />

                    <!-- 📥 日志输入框 —— 带深色边框的视觉层次 -->
                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="0,0,0,8"
                            Padding="2">
                        <TextBox Text="{Binding LogInput, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="100"
                                 MaxHeight="200"
                                 materialDesign:HintAssist.Hint="把日志粘在这里..."
                                 FontFamily="{DynamicResource AppMonospaceFontFamily}"
                                 FontSize="12" />
                    </Border>

                    <!-- 🔍 分析按钮 —— 点一下 AI 就开始干活 -->
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding AnalyzeLogCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconFontAwesome6 Kind="MagnifyingGlassSolid"
                                                    Width="18" Height="18"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0" />
                            <TextBlock Text="分析日志"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- 📊 日志分析输出 —— 终端风格展示 -->
                    <TextBlock Text="AI 分析结果"
                               FontSize="14" FontWeight="Medium"
                               Margin="0,0,0,4" />
                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="8"
                            Padding="4">
                        <TextBox Text="{Binding AnalysisOutput}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="80"
                                 MaxHeight="200"
                                 FontFamily="{DynamicResource AppMonospaceFontFamily}"
                                 FontSize="12"
                                 Foreground="{DynamicResource InfoInputForegroundBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 CaretBrush="{DynamicResource InfoInputForegroundBrush}" />
                    </Border>
                </StackPanel>
            </materialDesign:Card>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- 💡 配置建议列表 —— 左边彩色边框指示严重程度 -->
            <!-- ═══════════════════════════════════════════════ -->
            <materialDesign:Card Margin="0,0,0,8" Padding="16"
                                 Visibility="{Binding HasSuggestions, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="配置优化建议"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding ConfigSuggestions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- 💡 每条建议一张卡片，左边加条彩色边框 -->
                                <Border Margin="0,0,0,8"
                                        CornerRadius="4"
                                        BorderThickness="4,0,0,0"
                                        BorderBrush="{DynamicResource GaugeYellowBrush}">
                                    <Grid Margin="12,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 🏷️ 类别标签 -->
                                        <materialDesign:Chip Grid.Row="0" Grid.Column="0"
                                                               Content="{Binding Category}"
                                                               Margin="0,0,8,4" />

                                        <!-- 📊 当前值 -> 建议值 -->
                                        <StackPanel Grid.Row="0" Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Margin="0,0,0,4">
                                            <TextBlock Text="当前: "
                                                       Opacity="0.7" />
                                            <TextBlock Text="{Binding CurrentValue}"
                                                       FontWeight="Medium"
                                                       TextDecorations="Strikethrough" />
                                            <TextBlock Text=" → 建议使用: "
                                                       Opacity="0.7"
                                                       Margin="8,0,0,0" />
                                            <TextBlock Text="{Binding SuggestedValue}"
                                                       FontWeight="Bold"
                                                       Foreground="Lime" />
                                        </StackPanel>

                                        <!-- 📝 原因说明 -->
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding Reason}"
                                                   FontSize="12"
                                                   Opacity="0.8"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,4" />

                                        <!-- 🎯 预期影响 -->
                                        <StackPanel Grid.Row="2" Grid.Column="1"
                                                    Orientation="Horizontal">
                                            <TextBlock Text="预期影响: "
                                                       FontSize="11"
                                                       Opacity="0.6" />
                                            <materialDesign:Chip Content="{Binding Impact}"
                                                               FontSize="11" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
