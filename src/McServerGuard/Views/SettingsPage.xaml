<UserControl x:Class="McServerGuard.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:controls="clr-namespace:McServerGuard.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,16,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        </Style>

        <Style x:Key="SettingLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,8,0,4" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        </Style>

        <Style x:Key="SettingValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SubtleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="ColorSwatchStyle" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White" />
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="8" ShadowDepth="0" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.9" ScaleY="0.9" CenterX="20" CenterY="20" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 🎨 标题 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <iconPacks:PackIconFontAwesome6 Kind="GearSolid" Width="32" Height="32" 
                                             Foreground="{DynamicResource AccentTextBrush}" 
                                             Margin="0,0,12,0" />
                    <StackPanel>
                        <TextBlock Text="外观设置" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="自定义颜色、圆角和动画效果" FontSize="13" 
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </StackPanel>
                </StackPanel>

                <!-- 🎨 颜色设置 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="颜色方案" Style="{StaticResource SectionTitleStyle}" />
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 主色调 -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="主色调" Style="{StaticResource SettingLabelStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border x:Name="PrimaryColorPreview"
                                            Background="{Binding PrimaryColorBrush}" 
                                            BorderBrush="{DynamicResource SwatchHoverBorderBrush}" BorderThickness="2"
                                            CornerRadius="8" Width="50" Height="50"
                                            Margin="0,0,12,0"
                                            Cursor="Hand"
                                            ToolTip="点击打开取色器"
                                            MouseLeftButtonDown="PrimaryColorPreview_MouseLeftButtonDown" />
                                    <StackPanel>
                                        <TextBox Text="{Binding PrimaryColorHex}" 
                                                 materialDesign:HintAssist.Hint="{Binding PrimaryColorHex}"
                                                 FontSize="12"
                                                 Width="120"
                                                 Padding="8,4"
                                                 LostFocus="PrimaryColorHex_LostFocus" />
                                        <TextBlock Text="输入 HEX 值后失焦生效" FontSize="10" 
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="用于标题栏、按钮等主要元素" Style="{StaticResource SettingValueStyle}" />

                                <!-- 主色调预设 -->
                                <TextBlock Text="预设主色" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,4" />
                                <WrapPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="{DynamicResource PrimaryHueMidBrush}"
                                            Command="{Binding SetPrimaryColorCommand}"
                                            CommandParameter="#FF7B1FA2"
                                            ToolTip="深紫" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#1565C0"
                                            Command="{Binding SetPrimaryColorCommand}"
                                            CommandParameter="#FF1565C0"
                                            ToolTip="蓝" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#00897B"
                                            Command="{Binding SetPrimaryColorCommand}"
                                            CommandParameter="#FF00897B"
                                            ToolTip="青绿" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#C62828"
                                            Command="{Binding SetPrimaryColorCommand}"
                                            CommandParameter="#FFC62828"
                                            ToolTip="红" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#F57C00"
                                            Command="{Binding SetPrimaryColorCommand}"
                                            CommandParameter="#FFF57C00"
                                            ToolTip="橙" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#2E7D32"
                                            Command="{Binding SetPrimaryColorCommand}"
                                            CommandParameter="#FF2E7D32"
                                            ToolTip="绿" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#0D47A1"
                                            Command="{Binding SetPrimaryColorCommand}"
                                            CommandParameter="#FF0D47A1"
                                            ToolTip="深蓝" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#4A148C"
                                            Command="{Binding SetPrimaryColorCommand}"
                                            CommandParameter="#FF4A148C"
                                            ToolTip="深紫红" />
                                </WrapPanel>
                            </StackPanel>

                            <!-- 强调色 -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="强调色" Style="{StaticResource SettingLabelStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border x:Name="AccentColorPreview"
                                            Background="{Binding AccentColorBrush}" 
                                            BorderBrush="{DynamicResource SwatchHoverBorderBrush}" BorderThickness="2"
                                            CornerRadius="8" Width="50" Height="50"
                                            Margin="0,0,12,0"
                                            Cursor="Hand"
                                            ToolTip="点击打开取色器"
                                            MouseLeftButtonDown="AccentColorPreview_MouseLeftButtonDown" />
                                    <StackPanel>
                                        <TextBox Text="{Binding AccentColorHex}"
                                                 materialDesign:HintAssist.Hint="{Binding AccentColorHex}"
                                                 FontSize="12"
                                                 Width="120"
                                                 Padding="8,4"
                                                 LostFocus="AccentColorHex_LostFocus" />
                                        <TextBlock Text="输入 HEX 值后失焦生效" FontSize="10" 
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="用于高亮文字、图标等强调元素" Style="{StaticResource SettingValueStyle}" />

                                <!-- 强调色预设 -->
                                <TextBlock Text="预设强调色" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,4" />
                                <WrapPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#CDDC39"
                                            Command="{Binding SetAccentColorCommand}"
                                            CommandParameter="#FFCDDC39"
                                            ToolTip="青柠" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#FF9800"
                                            Command="{Binding SetAccentColorCommand}"
                                            CommandParameter="#FFFF9800"
                                            ToolTip="橙" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#E91E63"
                                            Command="{Binding SetAccentColorCommand}"
                                            CommandParameter="#FFE91E63"
                                            ToolTip="粉红" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#FFD600"
                                            Command="{Binding SetAccentColorCommand}"
                                            CommandParameter="#FFFFD600"
                                            ToolTip="黄" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#00BCD4"
                                            Command="{Binding SetAccentColorCommand}"
                                            CommandParameter="#FF00BCD4"
                                            ToolTip="青" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#8BC34A"
                                            Command="{Binding SetAccentColorCommand}"
                                            CommandParameter="#FF8BC34A"
                                            ToolTip="浅绿" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#FF5722"
                                            Command="{Binding SetAccentColorCommand}"
                                            CommandParameter="#FFFF5722"
                                            ToolTip="深橙" />
                                    <Button Style="{StaticResource ColorSwatchStyle}" 
                                            Background="#E91E63"
                                            Command="{Binding SetAccentColorCommand}"
                                            CommandParameter="#FFE91E63"
                                            ToolTip="粉红" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>

                        <!-- 快速预设方案 -->
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="快速方案" Style="{StaticResource SettingLabelStyle}" />
                            <WrapPanel Orientation="Horizontal">
                                <Button Command="{Binding SetPresetCommand}" CommandParameter="SkyBlue"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,8"
                                        Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#3B82F6" Width="20" Height="20" CornerRadius="4" />
                                        <Border Background="#FB7185" Width="20" Height="20" CornerRadius="4" Margin="4,0,0,0" />
                                        <TextBlock Text="苍穹蓝" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SetPresetCommand}" CommandParameter="BlueOrange"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,8"
                                        Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#1565C0" Width="20" Height="20" CornerRadius="4" />
                                        <Border Background="#FF9800" Width="20" Height="20" CornerRadius="4" Margin="4,0,0,0" />
                                        <TextBlock Text="科技蓝" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SetPresetCommand}" CommandParameter="TealPink"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,8"
                                        Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#00897B" Width="20" Height="20" CornerRadius="4" />
                                        <Border Background="#E91E63" Width="20" Height="20" CornerRadius="4" Margin="4,0,0,0" />
                                        <TextBlock Text="清新绿" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding SetPresetCommand}" CommandParameter="RedYellow"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,8"
                                        Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#C62828" Width="20" Height="20" CornerRadius="4" />
                                        <Border Background="#FFD600" Width="20" Height="20" CornerRadius="4" Margin="4,0,0,0" />
                                        <TextBlock Text="火焰红" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 🎨 高级颜色 —— 独立控制背景/卡片/文字/边框，让自定义颜色真正覆盖整个软件 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="高级颜色" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="独立调整背景、卡片、文字、边框颜色，覆盖整个软件外观" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 🪟 背景色 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,16">
                                <TextBlock Text="背景色" Style="{StaticResource SettingLabelStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{Binding BackgroundColorBrush}"
                                            BorderBrush="{DynamicResource SwatchHoverBorderBrush}" BorderThickness="2"
                                            CornerRadius="8" Width="50" Height="50"
                                            Margin="0,0,12,0" />
                                    <StackPanel>
                                        <TextBox Text="{Binding BackgroundColorHex}"
                                                 materialDesign:HintAssist.Hint="{Binding BackgroundColorHex}"
                                                 FontSize="12" Width="120" Padding="8,4"
                                                 LostFocus="BackgroundColorHex_LostFocus" />
                                        <TextBlock Text="输入 HEX 值后失焦生效" FontSize="10"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="窗口与页面底色" Style="{StaticResource SettingValueStyle}" />
                            </StackPanel>

                            <!-- 🃏 卡片色 -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="卡片色" Style="{StaticResource SettingLabelStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{Binding CardColorBrush}"
                                            BorderBrush="{DynamicResource SwatchHoverBorderBrush}" BorderThickness="2"
                                            CornerRadius="8" Width="50" Height="50"
                                            Margin="0,0,12,0" />
                                    <StackPanel>
                                        <TextBox Text="{Binding CardColorHex}"
                                                 materialDesign:HintAssist.Hint="{Binding CardColorHex}"
                                                 FontSize="12" Width="120" Padding="8,4"
                                                 LostFocus="CardColorHex_LostFocus" />
                                        <TextBlock Text="输入 HEX 值后失焦生效" FontSize="10"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="所有卡片与终端背景" Style="{StaticResource SettingValueStyle}" />
                            </StackPanel>

                            <!-- ✏️ 文字色 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="文字色" Style="{StaticResource SettingLabelStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{Binding TextColorBrush}"
                                            BorderBrush="{DynamicResource SwatchHoverBorderBrush}" BorderThickness="2"
                                            CornerRadius="8" Width="50" Height="50"
                                            Margin="0,0,12,0" />
                                    <StackPanel>
                                        <TextBox Text="{Binding TextColorHex}"
                                                 materialDesign:HintAssist.Hint="{Binding TextColorHex}"
                                                 FontSize="12" Width="120" Padding="8,4"
                                                 LostFocus="TextColorHex_LostFocus" />
                                        <TextBlock Text="输入 HEX 值后失焦生效" FontSize="10"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="正文与次要文字" Style="{StaticResource SettingValueStyle}" />
                            </StackPanel>

                            <!-- 📏 边框色 -->
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="边框色" Style="{StaticResource SettingLabelStyle}" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="{Binding BorderColorBrush}"
                                            BorderBrush="{DynamicResource SwatchHoverBorderBrush}" BorderThickness="2"
                                            CornerRadius="8" Width="50" Height="50"
                                            Margin="0,0,12,0" />
                                    <StackPanel>
                                        <TextBox Text="{Binding BorderColorHex}"
                                                 materialDesign:HintAssist.Hint="{Binding BorderColorHex}"
                                                 FontSize="12" Width="120" Padding="8,4"
                                                 LostFocus="BorderColorHex_LostFocus" />
                                        <TextBlock Text="输入 HEX 值后失焦生效" FontSize="10"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="卡片与输入框边框" Style="{StaticResource SettingValueStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 📐 圆角设置 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="圆角设置" Style="{StaticResource SectionTitleStyle}" />
                        
                        <TextBlock Text="控件圆角半径" Style="{StaticResource SettingLabelStyle}" />
                        <Slider Minimum="0" Maximum="24" Value="{Binding CornerRadius}" 
                                TickFrequency="2" TickPlacement="BottomRight"
                                Width="400" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding CornerRadius, StringFormat='{}当前: {0}px'}" Style="{StaticResource SettingValueStyle}" />
                        <TextBlock Text="控制按钮、卡片、输入框等元素的圆角大小" 
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        
                        <!-- 圆角预览 -->
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="预览" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <Border Width="60" Height="36" 
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource AccentTextBrush}" BorderThickness="1"
                                        CornerRadius="{Binding CornerRadius}">
                                    <TextBlock Text="按钮" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                </Border>
                                <Border Width="80" Height="36" 
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource SubtleBorderBrush}" BorderThickness="1"
                                        CornerRadius="{Binding CornerRadius}"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="卡片" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                </Border>
                                <Border Width="100" Height="36" 
                                        Background="{DynamicResource SubtleBorderBrush}"
                                        CornerRadius="{Binding CornerRadius}"
                                        Margin="12,0,0,0">
                                    <TextBlock Text="输入框" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ✏️ 字体设置 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="字体设置" Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Text="字体族" Style="{StaticResource SettingLabelStyle}" />
                        <ComboBox ItemsSource="{Binding SystemFonts}"
                                  SelectedItem="{Binding FontFamily}"
                                  Width="300"
                                  materialDesign:HintAssist.Hint="选择字体" />
                        <TextBlock Text="更改全局字体（需点击应用后生效）" 
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}" 
                                   Margin="0,4,0,0" />

                        <!-- 字体预览 -->
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="预览" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,6" />
                            <Border Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource SubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16,12">
                                <StackPanel>
                                    <TextBlock FontSize="18" FontWeight="Bold"
                                               FontFamily="{Binding FontFamily}"
                                               Text="MSMC 字体预览" />
                                    <TextBlock FontSize="14" Margin="0,8,0,0"
                                               FontFamily="{Binding FontFamily}"
                                               Text="快速的棕色狐狸跳过了懒狗。The quick brown fox jumps over the lazy dog." />
                                    <TextBlock FontSize="12" Margin="0,8,0,0"
                                               FontFamily="{Binding FontFamily}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               Text="1234567890 !@#$%^&amp;*() 测试数字和符号" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 🎬 动画设置 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="动画设置" Style="{StaticResource SectionTitleStyle}" />
                        
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <ToggleButton IsChecked="{Binding EnableAnimations}"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          VerticalAlignment="Center" />
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="启用动画效果" VerticalAlignment="Center" />
                                <TextBlock Text="页面切换、按钮悬停等动效" FontSize="11" 
                                           Foreground="{DynamicResource MaterialDesignBodyLight}" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="动画速度" Style="{StaticResource SettingLabelStyle}" />
                        <Slider Minimum="50" Maximum="1000" Value="{Binding AnimationDuration}" 
                                TickFrequency="50" TickPlacement="BottomRight"
                                Width="400" Margin="0,0,0,8"
                                IsEnabled="{Binding EnableAnimations}" />
                        <TextBlock Text="{Binding AnimationDuration, StringFormat='{}当前: {0}ms'}" 
                                   Style="{StaticResource SettingValueStyle}" />
                        <TextBlock Text="控制页面切换、按钮悬停等动画的持续时间" 
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </StackPanel>
                </Border>

                <!-- 🔔 通知设置 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="通知设置" Style="{StaticResource SectionTitleStyle}" />
                        
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <ToggleButton IsChecked="True"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          VerticalAlignment="Center" />
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="Windows 通知中心" VerticalAlignment="Center" />
                                <TextBlock Text="重要信息通过系统通知弹出" FontSize="11" 
                                           Foreground="{DynamicResource MaterialDesignBodyLight}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Command="{Binding TestNotificationCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,12,0,0"
                                Padding="16,8"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="BellSolid" Width="16" Height="16" />
                                <TextBlock Text="发送测试通知" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="点击测试按钮可以验证通知功能是否正常工作" 
                                   FontSize="12" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- ℹ️ 关于 -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="关于 MSMC" Style="{StaticResource SectionTitleStyle}" />

                        <!-- 项目信息 -->
                        <StackPanel Margin="0,4,0,16"
                                    HorizontalAlignment="Center">
                            <Border Width="64" Height="64"
                                    CornerRadius="16"
                                    Background="{DynamicResource PrimarySubtleBorderBrush}"
                                    HorizontalAlignment="Center">
                                <Viewbox Width="40" Height="40"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:PackIconFontAwesome6 Kind="ShieldSolid"
                                                            Foreground="{DynamicResource AccentTextBrush}" />
                                </Viewbox>
                            </Border>
                            <TextBlock Text="MSMC"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesignBody}"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,2" />
                            <TextBlock Text="Minecraft Server Management Console"
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="v0.1.0"
                                       FontSize="11"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       Opacity="0.7"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- 开发团队 -->
                        <TextBlock Text="开发团队"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   Margin="0,4,0,8" />

                        <!-- ABI-ZTROS + 烟蓝湘 情侣卡片 💖 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- ABI-ZTROS - 主要开发 -->
                            <Border x:Name="AuthorCard_ABI_ZTROS"
                                    Grid.Column="0"
                                    Background="{DynamicResource SubtleBorderBrush}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="AuthorCard_ABI_ZTROS_MouseLeftButtonDown">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="48" Height="48"
                                            CornerRadius="12"
                                            Background="{DynamicResource CardBackgroundBrush}">
                                        <Image Source="https://github.com/ABI-ZTROS.png"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="ABI-ZTROS"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource MaterialDesignBody}" />
                                        <TextBlock Text="主要开发 · 项目发起者"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,4,0,0">
                                            <iconPacks:PackIconFontAwesome6 Kind="GithubBrands"
                                                                     Width="12" Height="12"
                                                                     Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="github.com/ABI-ZTROS"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                       Margin="4,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 💖 中间的爱心 —— 你懂的 -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="8,0"
                                        HorizontalAlignment="Center">
                                <iconPacks:PackIconFontAwesome6 Kind="HeartSolid"
                                                        Width="20" Height="20"
                                                        Foreground="#FB7185"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center" />
                                <TextBlock Text="💞"
                                           FontSize="10"
                                           Foreground="#FB7185"
                                           Margin="0,2,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- 烟蓝湘 - 情绪支持 -->
                            <Border Grid.Column="2"
                                    Background="{DynamicResource SubtleBorderBrush}"
                                    CornerRadius="10"
                                    Padding="12">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="48" Height="48"
                                            CornerRadius="12"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            ClipToBounds="True">
                                        <Image Source="pack://application:,,,/Resources/Images/yanlanxiang.jpg"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="烟蓝湘"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource MaterialDesignBody}" />
                                        <TextBlock Text="情绪支持"
                                                   FontSize="11"
                                                   Foreground="#FB7185" />
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,4,0,0">
                                            <iconPacks:PackIconFontAwesome6 Kind="HeartSolid"
                                                                     Width="12" Height="12"
                                                                     Foreground="#FB7185"
                                                                     Opacity="0.7"
                                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="Special Thanks 💖"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                       Margin="4,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 次级开发者 - Gglaoguan -->
                        <Border x:Name="AuthorCard_Gglaoguan"
                                Background="{DynamicResource SubtleBorderBrush}"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,0,0,8"
                                Cursor="Hand"
                                MouseLeftButtonDown="AuthorCard_Gglaoguan_MouseLeftButtonDown">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="48" Height="48"
                                        CornerRadius="12"
                                        Background="{DynamicResource CardBackgroundBrush}">
                                    <Image Source="https://github.com/Gglaoguan.png"
                                           Stretch="UniformToFill" />
                                </Border>
                                <StackPanel Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Gglaoguan"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource MaterialDesignBody}" />
                                    <TextBlock Text="次级开发"
                                               FontSize="11"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,4,0,0">
                                        <iconPacks:PackIconFontAwesome6 Kind="GithubBrands"
                                                                 Width="12" Height="12"
                                                                 Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="github.com/Gglaoguan"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   Margin="4,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 两列布局：Mocha + CatStack -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- MochaCello92377 -->
                            <Border x:Name="AuthorCard_MochaCello92377"
                                    Grid.Column="0"
                                    Background="{DynamicResource SubtleBorderBrush}"
                                    CornerRadius="10"
                                    Padding="10"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="AuthorCard_MochaCello92377_MouseLeftButtonDown">
                                <StackPanel>
                                    <Border Width="40" Height="40"
                                            CornerRadius="10"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            HorizontalAlignment="Center">
                                        <Image Source="https://github.com/MochaCello92377.png"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Text="MochaCello92377"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource MaterialDesignBody}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,2" />
                                    <TextBlock Text="Debug · 功能建议"
                                               FontSize="10"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               HorizontalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,4,0,0">
                                        <iconPacks:PackIconFontAwesome6 Kind="GithubBrands"
                                                                 Width="10" Height="10"
                                                                 Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="GitHub"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   Margin="2,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- CatStack-pixe -->
                            <Border x:Name="AuthorCard_CatStack_pixe"
                                    Grid.Column="2"
                                    Background="{DynamicResource SubtleBorderBrush}"
                                    CornerRadius="10"
                                    Padding="10"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="AuthorCard_CatStack_pixe_MouseLeftButtonDown">
                                <StackPanel>
                                    <Border Width="40" Height="40"
                                            CornerRadius="10"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            HorizontalAlignment="Center">
                                        <Image Source="https://github.com/CatStack-pixe.png"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Text="CatStack-pixe"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource MaterialDesignBody}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,2" />
                                    <TextBlock Text="测试环境"
                                               FontSize="10"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               HorizontalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,4,0,0">
                                        <iconPacks:PackIconFontAwesome6 Kind="GithubBrands"
                                                                 Width="10" Height="10"
                                                                 Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="GitHub"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   Margin="2,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 📋 操作按钮 -->
                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Command="{Binding ResetToDefaultCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="16,10" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconFontAwesome6 Kind="RotateSolid" Width="16" Height="16" />
                            <TextBlock Text="重置为默认" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ApplyAndSaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource AccentGradientBrush}"
                            Foreground="White"
                            Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconFontAwesome6 Kind="CheckSolid" Width="16" Height="16" />
                            <TextBlock Text="应用并保存" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 📊 状态信息 -->
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="12" 
                           Foreground="{DynamicResource AccentTextBrush}" 
                           Margin="0,16,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- 🎨 取色器 Popup -->
        <Popup x:Name="ColorPickerPopup"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <controls:ColorPickerControl x:Name="ColorPicker" />
        </Popup>
    </Grid>
</UserControl>
