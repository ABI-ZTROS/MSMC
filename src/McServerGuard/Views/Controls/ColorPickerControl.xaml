<UserControl x:Class="McServerGuard.Views.Controls.ColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="280"
             Padding="0">
    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource SubtleBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
    <StackPanel>
        <TextBlock Text="取色器" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />

        <!-- 颜色预览 -->
        <Border x:Name="PreviewBorder"
                Height="50"
                CornerRadius="6"
                BorderBrush="{DynamicResource SubtleBorderBrush}"
                BorderThickness="1"
                Margin="0,0,0,12">
            <Border.Background>
                <SolidColorBrush x:Name="PreviewBrush" Color="{DynamicResource NavItemSelectedBrush}" />
            </Border.Background>
        </Border>

        <!-- R 滑块 -->
        <StackPanel Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="R" Width="20" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                <TextBlock x:Name="RValueText" Text="0" Width="30" HorizontalAlignment="Right" />
            </StackPanel>
            <Slider x:Name="RSlider"
                    Minimum="0" Maximum="255"
                    Value="0"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1" />
        </StackPanel>

        <!-- G 滑块 -->
        <StackPanel Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="G" Width="20" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                <TextBlock x:Name="GValueText" Text="151" Width="30" HorizontalAlignment="Right" />
            </StackPanel>
            <Slider x:Name="GSlider"
                    Minimum="0" Maximum="255"
                    Value="151"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1" />
        </StackPanel>

        <!-- B 滑块 -->
        <StackPanel Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="B" Width="20" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                <TextBlock x:Name="BValueText" Text="167" Width="30" HorizontalAlignment="Right" />
            </StackPanel>
            <Slider x:Name="BSlider"
                    Minimum="0" Maximum="255"
                    Value="167"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1" />
        </StackPanel>

        <!-- HEX 输入 -->
        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="HEX" VerticalAlignment="Center" Width="30"
                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
            <TextBox x:Name="HexTextBox"
                     materialDesign:HintAssist.Hint="HEX"
                     FontFamily="{DynamicResource AppMonospaceFontFamily}"
                     FontSize="12"
                     Padding="8,4"
                     Margin="8,0,0,0"
                     VerticalContentAlignment="Center" />
        </StackPanel>
    </StackPanel>
    </Border>
</UserControl>
