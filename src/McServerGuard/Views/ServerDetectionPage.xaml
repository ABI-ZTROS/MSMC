<!-- 🎮 服务器管理页面 —— 左侧紧凑列表 + 右侧 Tab 切换 + 底部命令预览 -->
<!-- 设计理念：突出主要操作、功能锁防冲突、状态色一目了然 -->
<UserControl x:Class="McServerGuard.Views.ServerDetectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:controls="clr-namespace:McServerGuard.Views.Controls"
             xmlns:converters="clr-namespace:McServerGuard.Converters"
             xmlns:models="clr-namespace:McServerGuard.Models">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/McServerGuard;component/Themes/AppResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <CubicEase x:Key="ServerCardEase" EasingMode="EaseOut" />

            <!-- 🎯 紧凑型服务器列表项模板：图标 + 状态点 + 名称 + 操作按钮 -->
            <Style x:Key="CompactServerItemBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="Margin" Value="0,0,0,2" />
                <Setter Property="Cursor" Value="Hand" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackgroundBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- 📋 通用 Section 标题 -->
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="4,8,4,4" />
                <Setter Property="Opacity" Value="0.7" />
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
            </Style>

            <Style x:Key="PresetButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <!-- 🎯 状态点（圆点 + 颜色 + 图标） -->
            <Style x:Key="StatusDotStyle" TargetType="Ellipse">
                <Setter Property="Width" Value="8" />
                <Setter Property="Height" Value="8" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,0,6,0" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 📐 整体布局：DockPanel（顶→底→中）                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <DockPanel LastChildFill="True">

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- 🎛️ 顶部操作条：检测 + 导入 + 状态点 + 忙碌提示          -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardSubtleBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 🎮 主要操作按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Command="{Binding DetectCommand}"
                                IsEnabled="{Binding IsIdle}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="White"
                                Padding="14,8"
                                Margin="0,0,8,0"
                                ToolTip="立即刷新服务器列表">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="ArrowsRotateSolid" Width="14" Height="14" />
                                <TextBlock Text="刷新" Margin="6,0,0,0" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ToggleAutoDetectCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="10,8"
                                Margin="0,0,8,0"
                                ToolTip="{Binding AutoDetectStatusText}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="{Binding AutoDetectIcon}" Width="12" Height="12" />
                                <TextBlock Text="{Binding AutoDetectStatusText}" Margin="6,0,0,0" FontSize="12" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding BrowseAndImportServerCommand}"
                                IsEnabled="{Binding IsIdle}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="14,8"
                                ToolTip="选择 JAR 文件导入到已知服务器列表">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="PlusSolid" Width="14" Height="14" />
                                <TextBlock Text="导入服务器" Margin="6,0,0,0" FontSize="12" FontWeight="Medium" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- ⏵ 当前选中服务器 + 状态点 -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding HasSelectedServer, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Ellipse Style="{StaticResource StatusDotStyle}"
                                 Fill="{Binding CurrentServerStatusBrush}" />
                        <TextBlock Text="{Binding CurrentServerStatusText}"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                        <TextBlock Text=" · "
                                   FontSize="12"
                                   Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding SelectedServerSubtitle}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="280" />
                    </StackPanel>

                    <!-- 🔒 忙碌提示 -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource MaterialDesignCardBackgroundBrush}"
                            CornerRadius="6"
                            Padding="10,6"
                            VerticalAlignment="Center"
                            Visibility="{Binding CanShowOperation, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         IsIndeterminate="True"
                                         Width="14" Height="14"
                                         Margin="0,0,8,0" />
                            <TextBlock Text="{Binding BusyReasonText}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- 📋 底部固定启动命令预览（永远可见）                       -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Bottom"
                    Background="{DynamicResource TerminalBackgroundBrush}"
                    BorderBrush="{DynamicResource CardSubtleBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- ▶ 标签 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconFontAwesome6 Kind="TerminalSolid"
                                                Width="14" Height="14"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"
                                                Foreground="{DynamicResource SuccessInputForegroundBrush}" />
                        <TextBlock Text="启动命令"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SuccessInputForegroundBrush}" />
                    </StackPanel>

                    <!-- 完整命令 -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding StartupCommandPreview}"
                               FontFamily="{DynamicResource AppMonospaceFontFamily}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="10,0"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource SuccessInputForegroundBrush}"
                               ToolTip="{Binding StartupCommandPreview}" />

                    <!-- 📋 复制按钮 -->
                    <Button Grid.Column="2"
                            Command="{Binding CopyStartupCommandCommand}"
                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                            ToolTip="复制启动命令到剪贴板"
                            Width="32" Height="32"
                            Padding="0">
                        <iconPacks:PackIconFontAwesome6 Kind="CopySolid" Width="14" Height="14" />
                    </Button>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- 📑 中间：左 280px 列表 + 右 Tab 切换                      -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- 📋 左侧：紧凑服务器列表 + 搜索                       -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <Border Grid.Column="0"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardSubtleBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">

                        <!-- 🔍 搜索框（顶部固定） -->
                        <Border DockPanel.Dock="Top" Padding="8,8,8,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconFontAwesome6 Grid.Column="0"
                                                        Kind="MagnifyingGlassSolid"
                                                        Width="12" Height="12"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0"
                                                        Opacity="0.6" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="搜索服务器..."
                                         materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                         BorderThickness="0"
                                         FontSize="12"
                                         Padding="0,4"
                                         Background="Transparent" />
                                <Button Grid.Column="2"
                                        Click="ClearSearch_Click"
                                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        Width="28" Height="28" Padding="0"
                                        Visibility="{Binding HasSearchKeyword, Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTip="清空搜索">
                                    <iconPacks:PackIconFontAwesome6 Kind="XmarkSolid" Width="12" Height="12" />
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 📜 列表区域 -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,0,8,8">
                            <StackPanel>

                                <!-- 🟢 运行中分组 -->
                                <Expander IsExpanded="True" Margin="0,4,0,0">
                                    <Expander.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <iconPacks:PackIconFontAwesome6 Kind="ServerSolid"
                                                                        Width="12" Height="12"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,0,6,0" />
                                                <TextBlock Text="运行中" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="{DynamicResource AccentGradientBrush}" CornerRadius="8" Padding="6,1">
                                                <TextBlock Text="{Binding DetectionResult.Servers.Count, FallbackValue=0}"
                                                           FontSize="10" FontWeight="Bold" Foreground="White" />
                                            </Border>
                                        </Grid>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding FilteredRunningServers}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="RunningItemBorder"
                                                        Style="{StaticResource CompactServerItemBorderStyle}"
                                                        Tag="{Binding}"
                                                        MouseLeftButtonUp="RunningItem_MouseLeftButtonUp">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 状态点 -->
                                                        <Ellipse Grid.Column="0"
                                                                 Style="{StaticResource StatusDotStyle}"
                                                                 Fill="{DynamicResource GaugeGreenBrush}" />

                                                        <!-- 名称 -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontSize="11" FontWeight="Medium"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding FormattedMaxMemory, StringFormat='内存 {0}'}"
                                                                       FontSize="9" Opacity="0.6" />
                                                        </StackPanel>

                                                        <!-- ▶ 快捷启动 -->
                                                        <Button Grid.Column="2"
                                                                Command="{Binding DataContext.StartCurrentServerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                Width="32" Height="32" Padding="0"
                                                                ToolTip="启动">
                                                            <iconPacks:PackIconFontAwesome6 Kind="PlaySolid" Width="14" Height="14" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=RunningItemBorder}" Value="True">
                                                        <Setter TargetName="RunningItemBorder" Property="Background" Value="{DynamicResource MaterialDesignCardBackgroundBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- 📚 已知服务器分组 -->
                                <Expander IsExpanded="True" Margin="0,8,0,0">
                                    <Expander.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <iconPacks:PackIconFontAwesome6 Kind="DatabaseSolid"
                                                                        Width="12" Height="12"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,0,6,0"
                                                                        Foreground="{DynamicResource AccentTextBrush}" />
                                                <TextBlock Text="已知服务器" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="{DynamicResource AccentGradientBrush}" CornerRadius="8" Padding="6,1">
                                                <TextBlock Text="{Binding KnownServers.Count, FallbackValue=0}"
                                                           FontSize="10" FontWeight="Bold" Foreground="White" />
                                            </Border>
                                        </Grid>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding FilteredKnownServers}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="KnownItemBorder"
                                                        Style="{StaticResource CompactServerItemBorderStyle}"
                                                        Tag="{Binding}"
                                                        MouseLeftButtonUp="KnownItem_MouseLeftButtonUp">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 收藏星 -->
                                                        <iconPacks:PackIconFontAwesome6 Grid.Column="0"
                                                                                Kind="StarSolid"
                                                                                Width="10" Height="10"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,6,0"
                                                                                Foreground="{DynamicResource AccentTextBrush}" />

                                                        <!-- 名称 -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="11" FontWeight="Medium"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Port, StringFormat='端口 {0}'}"
                                                                       FontSize="9" Opacity="0.6" />
                                                        </StackPanel>

                                                        <!-- ▶ 启动 + 🗑 删除 -->
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                                                            <Button Command="{Binding DataContext.StartKnownServerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                    Width="32" Height="32" Padding="0"
                                                                    ToolTip="启动">
                                                                <iconPacks:PackIconFontAwesome6 Kind="PlaySolid" Width="14" Height="14" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                                            </Button>
                                                            <Button Command="{Binding DataContext.RemoveKnownServerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                    Width="32" Height="32" Padding="0"
                                                                    ToolTip="删除">
                                                                <iconPacks:PackIconFontAwesome6 Kind="TrashCanSolid" Width="14" Height="14" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- 提示空状态 -->
                                <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0"
                                            Visibility="{Binding HasKnownServers, Converter={StaticResource InvertBoolToVisibilityConverter}}">
                                    <iconPacks:PackIconFontAwesome6 Kind="FolderOpenRegular"
                                                            Width="32" Height="32"
                                                            HorizontalAlignment="Center"
                                                            Opacity="0.3" />
                                    <TextBlock Text="还没有已知服务器"
                                               FontSize="11"
                                               Opacity="0.6"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0" />
                                    <TextBlock Text="点击「导入服务器」开始"
                                               FontSize="10"
                                               Opacity="0.5"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- 📑 右侧：Tab 切换（控制台 / JVM 参数 / 命令预览）      -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <Grid Grid.Column="1">
                    <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                                Style="{StaticResource MaterialDesignFilledTabControl}"
                                Background="Transparent"
                                BorderThickness="0">

                        <!-- 🎛️ Tab1：控制台（详情 + 总控按钮） -->
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconFontAwesome6 Kind="GaugeSolid" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="控制台" FontWeight="SemiBold" />
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                                <StackPanel>
                                    <!-- 🚀 总控按钮（启动/停止/保存） -->
                                    <materialDesign:Card Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="🚀 服务器控制" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />
                                            <StackPanel Orientation="Horizontal">
                                                <Button Command="{Binding StartCurrentServerCommand}"
                                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                                        Background="{DynamicResource PrimaryHueMidBrush}"
                                                        Foreground="White"
                                                        Padding="18,10"
                                                        Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconFontAwesome6 Kind="PlaySolid" Width="14" Height="14" />
                                                        <TextBlock Text="启动服务器" Margin="6,0,0,0" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Button>

                                                <Button Command="{Binding StopCurrentServerCommand}"
                                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                                        Background="{DynamicResource DangerBrush}"
                                                        Foreground="White"
                                                        Padding="18,10"
                                                        Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconFontAwesome6 Kind="StopSolid" Width="14" Height="14" />
                                                        <TextBlock Text="停止服务器" Margin="6,0,0,0" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Button>

                                                <Button Command="{Binding SaveAsKnownServerCommand}"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                                        Padding="18,10">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconFontAwesome6 Kind="FloppyDiskSolid" Width="14" Height="14" />
                                                        <TextBlock Text="保存到已知" Margin="6,0,0,0" FontWeight="Medium" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>

                                            <!-- 操作消息 -->
                                            <TextBlock Text="{Binding OperationMessage}"
                                                       FontSize="12"
                                                       Margin="0,12,0,0"
                                                       TextWrapping="Wrap"
                                                       Opacity="0.8" />
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- 📊 服务器详情 -->
                                    <materialDesign:Card Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="📊 服务器详情" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="工作路径" FontWeight="Medium" FontSize="12" Margin="0,0,8,8" Opacity="0.7" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedServer.WorkingDirectory}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="JAR 路径" FontWeight="Medium" FontSize="12" Margin="0,0,8,8" Opacity="0.7" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedServer.ServerJarPath}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="JAR 名称" FontWeight="Medium" FontSize="12" Margin="0,0,8,8" Opacity="0.7" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedServer.ServerJarName}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Java" FontWeight="Medium" FontSize="12" Margin="0,0,8,0" Opacity="0.7" />
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedServer.JavaPath}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- 📝 检测日志 -->
                                    <materialDesign:Card Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="📝 检测日志" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />
                                            <Border Background="{DynamicResource TerminalBackgroundBrush}" CornerRadius="6" Padding="8">
                                                <TextBox Text="{Binding DetectionLog, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         MinHeight="120"
                                                         MaxHeight="200"
                                                         FontFamily="{DynamicResource AppMonospaceFontFamily}"
                                                         FontSize="11"
                                                         Foreground="{DynamicResource SuccessInputForegroundBrush}"
                                                         Background="Transparent"
                                                         BorderThickness="0" />
                                            </Border>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ⚙️ Tab2：JVM 参数 -->
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconFontAwesome6 Kind="SlidersSolid" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="JVM 参数" FontWeight="SemiBold" />
                                </StackPanel>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                                <StackPanel>
                                    <materialDesign:Card Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="⚙️ JVM 参数设置" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />

                                            <!-- 💾 内存设置 -->
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="内存设置" />
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="初始堆内存 (-Xms)" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
                                                    <TextBox Text="{Binding InitialMemory, UpdateSourceTrigger=PropertyChanged}"
                                                             materialDesign:HintAssist.Hint="2G"
                                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="最大堆内存 (-Xmx)" FontSize="11" Opacity="0.7" Margin="0,0,0,4" />
                                                    <TextBox Text="{Binding MaxMemory, UpdateSourceTrigger=PropertyChanged}"
                                                             materialDesign:HintAssist.Hint="4G"
                                                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- 🎯 预设 -->
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="快速预设" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Button Command="{Binding ApplyAikarPresetCommand}" Style="{StaticResource PresetButtonStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconFontAwesome6 Kind="RocketSolid" Width="11" Height="11" />
                                                        <TextBlock Text="Aikar" Margin="4,0,0,0" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding ApplyG1GCPresetCommand}" Style="{StaticResource PresetButtonStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconFontAwesome6 Kind="GaugeHighSolid" Width="11" Height="11" />
                                                        <TextBlock Text="G1GC" Margin="4,0,0,0" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Command="{Binding ApplyZgcPresetCommand}" Style="{StaticResource PresetButtonStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconFontAwesome6 Kind="BoltSolid" Width="11" Height="11" />
                                                        <TextBlock Text="ZGC" Margin="4,0,0,0" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>

                                            <!-- 📂 参数分类 -->
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="参数分类" />
                                            <ItemsControl ItemsSource="{Binding AllArgumentCategories}" Margin="0,0,0,8">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                Padding="12,6" Margin="0,0,6,6" FontSize="11">
                                                            <TextBlock Text="{Binding}" />
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- ➕ 可选参数 -->
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="可选参数（点击添加）" />
                                            <ItemsControl ItemsSource="{Binding FilteredArguments}" Margin="0,0,0,12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.AddArgumentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding Flag}"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                Padding="12,6" Margin="0,0,6,6" FontSize="11"
                                                                ToolTip="{Binding Description}">
                                                            <TextBlock Text="{Binding Flag}" />
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- ✏️ 自定义参数 -->
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="自定义参数" />
                                            <DockPanel Margin="0,0,0,12">
                                                <Button DockPanel.Dock="Right"
                                                        Command="{Binding AddCustomArgumentCommand}"
                                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                                        Padding="12,6" Margin="8,0,0,0">
                                                    <TextBlock Text="添加" FontSize="11" />
                                                </Button>
                                                <TextBox Text="{Binding CustomArgument, UpdateSourceTrigger=PropertyChanged}"
                                                         materialDesign:HintAssist.Hint="输入自定义 JVM 参数"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                                            </DockPanel>

                                            <!-- 📋 已选参数列表 -->
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="已选参数" />
                                            <ItemsControl ItemsSource="{Binding SelectedArguments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource MaterialDesignCardBackgroundBrush}"
                                                                CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding}" FontSize="11" FontFamily="{DynamicResource AppMonospaceFontFamily}"
                                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <Button Command="{Binding DataContext.StartEditArgumentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                            Padding="6,4" MinWidth="28" MinHeight="28" ToolTip="编辑">
                                                                        <iconPacks:PackIconFontAwesome6 Kind="PenSolid" Width="12" Height="12" />
                                                                    </Button>
                                                                    <Button Command="{Binding DataContext.RemoveArgumentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                                            Padding="6,4" MinWidth="28" MinHeight="28" ToolTip="移除">
                                                                        <iconPacks:PackIconFontAwesome6 Kind="XmarkSolid" Width="12" Height="12" />
                                                                    </Button>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- 📋 Tab3：命令预览 -->
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconFontAwesome6 Kind="TerminalSolid" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="命令预览" FontWeight="SemiBold" />
                                </StackPanel>
                            </TabItem.Header>
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="完整启动命令" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                                    <Button Command="{Binding CopyStartupCommandCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Padding="12,6" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconFontAwesome6 Kind="CopySolid" Width="12" Height="12" />
                                            <TextBlock Text="复制" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Background="{DynamicResource TerminalBackgroundBrush}"
                                        CornerRadius="8" Padding="16">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding StartupCommandPreview}"
                                                   FontFamily="{DynamicResource AppMonospaceFontFamily}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SuccessInputForegroundBrush}" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Grid>
        </DockPanel>

        <!-- 🔄 检测中遮罩 -->
        <Border Background="{DynamicResource LoadingOverlayBrush}"
                CornerRadius="12"
                Visibility="{Binding CanShowOperation, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Loading"
                                        Width="48" Height="48"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,12"
                                        Foreground="White">
                    <materialDesign:PackIcon.RenderTransform>
                        <RotateTransform x:Name="LoadingIconRotate" CenterX="24" CenterY="24" />
                    </materialDesign:PackIcon.RenderTransform>
                    <materialDesign:PackIcon.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="LoadingIconRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:1"
                                                     RepeatBehavior="Forever" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </materialDesign:PackIcon.Triggers>
                </materialDesign:PackIcon>
                <TextBlock Text="{Binding BusyReasonText}"
                           FontSize="14"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Opacity="0.8" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
