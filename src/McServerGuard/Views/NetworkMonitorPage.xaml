<!-- 🌐 网络监控页面 —— 端口占用 / 常见端口 / 端口桥接 -->
<UserControl x:Class="McServerGuard.Views.NetworkMonitorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:constants="clr-namespace:McServerGuard.Constants">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- 📐 整体布局：顶部统计卡片条 + 下方左 Tab + 右图例               -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- 📊 顶部统计卡片条                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16">
            <materialDesign:Card Padding="16" Width="200" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="总端口数" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" />
                    <TextBlock Text="{Binding TotalPorts}" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Foreground="{DynamicResource PrimaryHueLightBrush}" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="16" Width="200" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="已占用" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" />
                    <TextBlock Text="{Binding UsedPorts}" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Foreground="{DynamicResource SecondaryHueLightBrush}" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="16" Width="200" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="占用率" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.6" />
                    <TextBlock Text="{Binding UsedPercentage, StringFormat={}{0}%}" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                </StackPanel>
            </materialDesign:Card>

            <Button Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsRefreshing, Converter={StaticResource InvertBoolConverter}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,0,0,0"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconFontAwesome6 Kind="ArrowsRotateSolid" Width="16" Height="16" />
                    <TextBlock Text="刷新" Margin="6,0,0,0" FontSize="12" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- 📑 中间：左 TabControl + 右端口图例                            -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- 📋 左侧 TabControl：端口占用 / 常见端口 / 端口桥接      -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <TabControl Grid.Column="0" Margin="0,0,16,0">

                <!-- ── Tab 1: 端口占用 ── -->
                <TabItem Header="端口占用">
                    <materialDesign:Card Padding="8">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Bottom"
                                    Command="{Binding KillProcessCommand}"
                                    IsEnabled="{Binding SelectedPort, Converter={StaticResource NullToBoolConverter}}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    HorizontalAlignment="Right"
                                    Margin="8">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconFontAwesome6 Kind="XmarkSolid" Width="16" Height="16" />
                                    <TextBlock Text="结束进程" Margin="6,0,0,0" FontSize="12" />
                                </StackPanel>
                            </Button>

                            <DataGrid ItemsSource="{Binding ListeningPorts}"
                                      SelectedItem="{Binding SelectedPort}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="80" />
                                    <DataGridTextColumn Header="协议" Binding="{Binding Protocol}" Width="60" />
                                    <DataGridTextColumn Header="进程名" Binding="{Binding ProcessName}" Width="*" />
                                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" />
                                    <DataGridTextColumn Header="范围" Binding="{Binding PortRange}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </materialDesign:Card>
                </TabItem>

                <!-- ── Tab 2: 常见端口 ── -->
                <TabItem Header="常见端口">
                    <materialDesign:Card Padding="8">
                        <DataGrid ItemsSource="{x:Static constants:CommonPorts.All}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="80" />
                                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="100" />
                                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*" />
                                <DataGridTextColumn Header="类别" Binding="{Binding Category}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </materialDesign:Card>
                </TabItem>

                <!-- ── Tab 3: 端口桥接 ── -->
                <TabItem Header="端口桥接">
                    <materialDesign:Card Padding="16">
                        <StackPanel>
                            <TextBlock Text="添加桥接规则" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="监听地址" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{x:Static constants:IpAddresses.All}"
                                          SelectedItem="{Binding BridgeListenAddress}"
                                          Margin="8,4,0,4" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="监听端口" VerticalAlignment="Center" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BridgeListenPort}" Margin="8,4,0,4" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="→" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="转发到" Opacity="0.6" VerticalAlignment="Center" Margin="8,4,0,4" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="目标地址" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="3" Grid.Column="1"
                                          ItemsSource="{x:Static constants:IpAddresses.All}"
                                          SelectedItem="{Binding BridgeConnectAddress}"
                                          Margin="8,4,0,4" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="目标端口" VerticalAlignment="Center" />
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BridgeConnectPort}" Margin="8,4,0,4" />

                                <CheckBox Grid.Row="5" Grid.Column="1"
                                          Content="同时添加防火墙规则"
                                          IsChecked="{Binding BridgeAddFirewall}"
                                          Margin="8,4,0,4" />
                            </Grid>

                            <Button Command="{Binding AddBridgeCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconFontAwesome6 Kind="PlusSolid" Width="16" Height="16" />
                                    <TextBlock Text="添加桥接" Margin="6,0,0,0" FontSize="12" />
                                </StackPanel>
                            </Button>

                            <Separator Margin="0,0,0,16" />

                            <TextBlock Text="现有桥接规则" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding BridgeRules}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="监听" Binding="{Binding ListenAddress}" Width="100" />
                                    <DataGridTextColumn Header="端口" Binding="{Binding ListenPort}" Width="80" />
                                    <DataGridTextColumn Header="目标" Binding="{Binding ConnectAddress}" Width="100" />
                                    <DataGridTextColumn Header="端口" Binding="{Binding ConnectPort}" Width="80" />
                                    <DataGridTemplateColumn Header="操作" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.RemoveBridgeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Foreground="{DynamicResource DangerBrush}">
                                                    <iconPacks:PackIconFontAwesome6 Kind="TrashSolid" Width="16" Height="16" />
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>
                </TabItem>
            </TabControl>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- 📊 右侧：端口范围图例（已移除 Viewport3D）              -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <materialDesign:Card Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="端口占用分布"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="16,16,16,8" />

                    <!-- 端口范围统计 -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Rectangle Width="16" Height="16" Fill="#FF3333" Margin="0,0,8,0" />
                            <TextBlock Text="系统端口 (0-1023)" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SystemPorts, StringFormat='  {0}'}" FontSize="12" VerticalAlignment="Center" Opacity="0.6" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Rectangle Width="16" Height="16" Fill="#3366FF" Margin="0,0,8,0" />
                            <TextBlock Text="注册端口 (1024-49151)" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RegisteredPorts, StringFormat='  {0}'}" FontSize="12" VerticalAlignment="Center" Opacity="0.6" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="16" Height="16" Fill="#33CC66" Margin="0,0,8,0" />
                            <TextBlock Text="动态端口 (49152-65535)" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding DynamicPorts, StringFormat='  {0}'}" FontSize="12" VerticalAlignment="Center" Opacity="0.6" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                               FontSize="11" Opacity="0.6"
                               Margin="16,0,16,12" TextTrimming="CharacterEllipsis" />
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
