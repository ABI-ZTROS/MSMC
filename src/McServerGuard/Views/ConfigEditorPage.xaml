<!-- 🎛️ 配置编辑页面 —— "你是 server.properties 的主治医生，开始诊断吧" -->
<UserControl x:Class="McServerGuard.Views.ConfigEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:McServerGuard.Converters"
             xmlns:selectors="clr-namespace:McServerGuard.Selectors">

    <UserControl.Resources>
        <!-- 🎢 配置卡片入场动画缓动函数 -->
        <CubicEase x:Key="ConfigCardEase" EasingMode="EaseOut" />

        <!-- 🎨 配置项卡片样式 -->
        <Style x:Key="ConfigItemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentSubtleBorderBrush}" />
                </Trigger>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)"
                                             From="0" To="1"
                                             Duration="0:0:0.25"
                                             EasingFunction="{StaticResource ConfigCardEase}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             From="12" To="0"
                                             Duration="0:0:0.3"
                                             EasingFunction="{StaticResource ConfigCardEase}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- 🎯 配置名文字样式 -->
        <Style x:Key="ConfigNameStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
        </Style>

        <!-- 💬 配置描述文字样式 -->
        <Style x:Key="ConfigDescStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <!-- 📂 分类 Expander 头部样式 -->
        <Style x:Key="CategoryExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- 🔘 分类标题文字样式 -->
        <Style x:Key="CategoryTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}" />
        </Style>

        <!-- 📝 配置值输入框样式 -->
        <Style x:Key="ConfigValueTextBoxStyle" TargetType="TextBox"
               BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Height" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <!-- 🎯 枚举下拉框样式 -->
        <Style x:Key="ConfigComboBoxStyle" TargetType="ComboBox"
               BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Height" Value="36" />
        </Style>

        <!-- 🎯 模板选择器：根据类型选择编辑模板（放在所有样式定义之后） -->
        <selectors:ConfigEditorTemplateSelector x:Key="ConfigEditorTemplateSelector">
            <selectors:ConfigEditorTemplateSelector.BoolTemplate>
                <DataTemplate>
                    <ToggleButton IsChecked="{Binding Value, Converter={StaticResource BoolStringConverter}, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                </DataTemplate>
            </selectors:ConfigEditorTemplateSelector.BoolTemplate>
            <selectors:ConfigEditorTemplateSelector.EnumTemplate>
                <DataTemplate>
                    <ComboBox ItemsSource="{Binding Descriptor.AllowedValues}"
                              SelectedItem="{Binding Value}"
                              Style="{StaticResource ConfigComboBoxStyle}" />
                </DataTemplate>
            </selectors:ConfigEditorTemplateSelector.EnumTemplate>
            <selectors:ConfigEditorTemplateSelector.NumericTemplate>
                <DataTemplate>
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ConfigValueTextBoxStyle}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveConfigCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        </TextBox.InputBindings>
                        <TextBox.ToolTip>
                            <StackPanel>
                                <TextBlock Text="默认值: ">
                                    <Run Text="{Binding Descriptor.DefaultValue, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="范围: " />
                                    <Run Text="{Binding Descriptor.MinValue, Mode=OneWay}" />
                                    <Run Text=" - " />
                                    <Run Text="{Binding Descriptor.MaxValue, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </TextBox.ToolTip>
                        <materialDesign:HintAssist.Hint>输入数值</materialDesign:HintAssist.Hint>
                    </TextBox>
                </DataTemplate>
            </selectors:ConfigEditorTemplateSelector.NumericTemplate>
            <selectors:ConfigEditorTemplateSelector.StringTemplate>
                <DataTemplate>
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ConfigValueTextBoxStyle}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding DataContext.SaveConfigCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                        </TextBox.InputBindings>
                        <materialDesign:HintAssist.Hint>输入文本</materialDesign:HintAssist.Hint>
                    </TextBox>
                </DataTemplate>
            </selectors:ConfigEditorTemplateSelector.StringTemplate>
        </selectors:ConfigEditorTemplateSelector>
    </UserControl.Resources>

    <!-- 📐 Grid 两列布局：左侧文件列表（260px）+ 右侧编辑区 -->
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />  <!-- 📁 左侧：配置文件列表 -->
            <ColumnDefinition Width="*" />     <!-- ✏️ 右侧：配置编辑区 -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- 📁 左侧 Card：配置文件列表 -->
        <!-- ═══════════════════════════════════════════════════ -->
        <materialDesign:Card Grid.Column="0"
                             Margin="0,0,12,0"
                             Padding="0"
                             UniformCornerRadius="12">
            <DockPanel>
                <!-- 🔝 标题栏 -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        CornerRadius="12,12,0,0"
                        Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconFontAwesome6 Kind="FolderOpenSolid"
                                                Width="20" Height="20"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0"
                                                Foreground="White" />
                        <TextBlock Text="配置文件"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="White" />
                    </StackPanel>
                </Border>

                <!-- 📋 文件列表 —— 选哪个文件就编辑哪个 -->
                <ListBox ItemsSource="{Binding ConfigFiles}"
                         SelectedItem="{Binding SelectedConfigFile}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}" />
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon x:Name="FileIcon"
                                                                         Grid.Column="0"
                                                                         Kind="FileDocumentOutline"
                                                                         Width="16" Height="16"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,8,0"
                                                                         Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                                <ContentPresenter Grid.Column="1"
                                                                  Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavItemHoverBrush}" />
                                                <Setter TargetName="FileIcon" Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimarySubtleBorderBrush}" />
                                                <Setter TargetName="FileIcon" Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 📊 文件统计信息 -->
                <Border DockPanel.Dock="Bottom"
                        Padding="12,8"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource CardSubtleBorderBrush}">
                    <TextBlock Text="{Binding ConfigFileCountText}"
                               FontSize="11"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Opacity="0.7" />
                </Border>
            </DockPanel>
        </materialDesign:Card>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ✏️ 右侧：保存/重置按钮 + 分类配置项编辑 -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- 🔘 按钮栏 -->
                <RowDefinition Height="*" />     <!-- 📝 配置项列表 -->
            </Grid.RowDefinitions>

            <!-- ═══ 🔘 顶部操作按钮栏 ═══ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="16,12"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 🏷️ 左侧：当前文件名 + 状态 -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedConfigFile}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <iconPacks:PackIconFontAwesome6 Kind="PenSolid"
                                                    Width="14" Height="14"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,4,0"
                                                    Opacity="0.6" />
                            <TextBlock Text="配置编辑器"
                                       FontSize="11"
                                       Opacity="0.6"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- 🔘 右侧：操作按钮 -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <!-- 🔄 重置按钮 -->
                        <Button Command="{Binding ResetChangesCommand}"
                                Margin="0,0,12,0"
                                Padding="16,0"
                                Height="36"
                                materialDesign:ButtonAssist.CornerRadius="8">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="RotateSolid"
                                                        Width="16" Height="16"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0" />
                                <TextBlock Text="重置修改" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- 💾 保存按钮 -->
                        <Button Command="{Binding SaveConfigCommand}"
                                Padding="20,0"
                                Height="36"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                ToolTip="Ctrl+S 也可以保存哦">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="FloppyDiskSolid"
                                                        Width="16" Height="16"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0" />
                                <TextBlock Text="保存配置"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ 📝 配置项：按分类分组的 Expander 列表（虚拟化） ═══ -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding GroupedConfigEntries}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- 📂 每个 Category 一个 Expander -->
                            <Expander IsExpanded="True"
                                      Style="{DynamicResource MaterialDesignExpander}"
                                      Margin="0,0,0,4">
                                <Expander.Triggers>
                                    <EventTrigger RoutedEvent="Expander.Expanded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.3" To="1"
                                                                 Duration="0:0:0.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Expander.Triggers>
                                <Expander.Header>
                                    <Border Padding="4,0">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconFontAwesome6 Kind="FolderSolid"
                                                                    Width="18" Height="18"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,8,0"
                                                                    Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                            <TextBlock Text="{Binding Key}"
                                                       Style="{StaticResource CategoryTitleStyle}" />
                                            <Border Background="{DynamicResource PrimaryHueMidBrush}"
                                                    CornerRadius="10"
                                                    Padding="6,2"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Items.Count}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Expander.Header>

                                <!-- 📋 分类下的配置项列表 -->
                                <ItemsControl ItemsSource="{Binding Items}"
                                              Margin="4,8,4,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- 🎛️ 单个配置项卡片 -->
                                            <Border Style="{StaticResource ConfigItemCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="220" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 🏷️ 左侧：配置名 + 描述 -->
                                                    <StackPanel Grid.Column="0"
                                                                VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding FriendlyDisplayName}"
                                                                       Style="{StaticResource ConfigNameStyle}" />
                                                            <!-- ⚠️ 需要重启标识 -->
                                                            <iconPacks:PackIconFontAwesome6 Kind="RotateLeftSolid"
                                                                                    Width="14" Height="14"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="6,0,0,0"
                                                                                    Foreground="{DynamicResource GaugeYellowBrush}"
                                                                                    ToolTip="修改此项需要重启服务器">
                                                                <iconPacks:PackIconFontAwesome6.Visibility>
                                                                    <Binding Path="RequiresRestart"
                                                                             Converter="{StaticResource BoolToVisibilityConverter}" />
                                                                </iconPacks:PackIconFontAwesome6.Visibility>
                                                            </iconPacks:PackIconFontAwesome6>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Style="{StaticResource ConfigDescStyle}"
                                                                   ToolTip="{Binding Description}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="44" />
                                                        <!-- 🔑 键名（小字显示） -->
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                                   Opacity="0.5"
                                                                   Margin="0,4,0,0"
                                                                   FontFamily="Consolas" />
                                                    </StackPanel>

                                                    <!-- ✏️ 右侧：编辑控件（根据类型动态选择模板） -->
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Right">
                                                        <ContentPresenter Content="{Binding}"
                                                                          ContentTemplateSelector="{StaticResource ConfigEditorTemplateSelector}" />

                                                        <!-- ⚠️ 验证错误提示 -->
                                                        <TextBlock Text="{Binding ErrorMessage}"
                                                                   Foreground="{DynamicResource ErrorTextBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="Medium"
                                                                   Margin="0,6,0,0">
                                                            <TextBlock.Visibility>
                                                                <Binding Path="IsValid"
                                                                         Converter="{StaticResource InvertBoolToVisibilityConverter}" />
                                                            </TextBlock.Visibility>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- 📌 修改状态指示器（左上角小圆点） -->
                                                    <Ellipse Grid.Column="1"
                                                             Width="8" Height="8"
                                                             VerticalAlignment="Top"
                                                             HorizontalAlignment="Right"
                                                             Margin="0,0,0,0"
                                                             Fill="{DynamicResource GaugeYellowBrush}">
                                                        <Ellipse.Visibility>
                                                            <Binding Path="IsModified"
                                                                     Converter="{StaticResource BoolToVisibilityConverter}" />
                                                        </Ellipse.Visibility>
                                                        <Ellipse.ToolTip>已修改，尚未保存</Ellipse.ToolTip>
                                                    </Ellipse>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            <!-- ⏳ 加载中指示器 -->
            <Border Grid.Row="1"
                    Background="{DynamicResource LoadingOverlayBrush}"
                    CornerRadius="12"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Loading"
                                             Width="48" Height="48"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}">
                        <materialDesign:PackIcon.RenderTransform>
                            <RotateTransform x:Name="LoadingIconRotate"
                                             Angle="0"
                                             CenterX="24"
                                             CenterY="24" />
                        </materialDesign:PackIcon.RenderTransform>
                        <materialDesign:PackIcon.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="LoadingIconRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360"
                                                         Duration="0:0:1"
                                                         RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </materialDesign:PackIcon.Triggers>
                    </materialDesign:PackIcon>
                    <TextBlock Text="正在加载配置..."
                               FontSize="14"
                               Margin="0,16,0,8"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBody}" />
                    <ProgressBar Value="{Binding LoadProgress}"
                                 Maximum="100"
                                 Width="200"
                                 Height="4"
                                 HorizontalAlignment="Center"
                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Text="{Binding LoadProgress, StringFormat={}{0}%}"
                               FontSize="11"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Opacity="0.7" />
                </StackPanel>
            </Border>

            <!-- 😶 还没选文件呢 —— 空状态 -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedConfigFile}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="16"
                        Padding="48,40">
                    <StackPanel>
                        <iconPacks:PackIconFontAwesome6 Kind="FileLinesSolid"
                                                Width="72" Height="72"
                                                HorizontalAlignment="Center"
                                                Opacity="0.3"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <TextBlock Text="选择左侧的配置文件"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,4" />
                        <TextBlock Text="开始编辑服务器配置"
                                   FontSize="13"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center" />
                        <Border Background="{DynamicResource AccentSubtleBorderBrush}"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconFontAwesome6 Kind="LightbulbSolid"
                                                        Width="16" Height="16"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Foreground="{DynamicResource AccentTextBrush}" />
                                <TextBlock Text="支持 server.properties / YAML / JSON 格式"
                                           FontSize="12"
                                           Foreground="{DynamicResource AccentTextBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
