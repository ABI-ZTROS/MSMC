<Application x:Class="McServerGuard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:McServerGuard.Converters"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 🎨 MaterialDesign 暗色主题 —— 苍穹蓝 + 暖珊瑚，清新科技感 -->
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                              PrimaryColor="Blue"
                                              SecondaryColor="Pink" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <!-- 🎨 自定义资源字典 —— 深度定制的笔刷、导航样式、卡片样式 -->
                <ResourceDictionary Source="/Themes/AppResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 🔄 全局转换器 —— 所有页面都能用 -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <converters:BoolStringConverter x:Key="BoolStringConverter" />
            <converters:ValueTypeToVisibilityConverter x:Key="ValueTypeToVisibilityConverter" />
            <converters:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter" />
            <converters:IndexToBoolConverter x:Key="IndexToBoolConverter" />
            <converters:BoolToPackIconConverter x:Key="BoolToPackIconConverter" />
            <converters:BoolToTextConverter x:Key="BoolToTextConverter" />
            <converters:BooleanToBrushConverter x:Key="BooleanToBrushConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
